FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string
SESSION_COOKIE_SECURE=true

# PostgreSQL (Railway adds this automatically when you add a PostgreSQL plugin)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLite fallback (used if DATABASE_URL is not set)
# DATABASE_URL=sqlite:///data/tasktracker.db
